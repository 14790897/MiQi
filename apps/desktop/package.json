{
  "name": "miqi-desktop",
  "version": "0.8.1",
  "description": "MiQi Desktop — native desktop companion for the MiQi AI agent",
  "main": "./out/main/electron-trampoline.js",
  "author": "MiQi Team",
  "repository": "http://git.miqroera.com/intership/miqi-desktop",
  "scripts": {
    "predev": "cd ../.. && uv sync && uv pip install lxml cryptography --quiet",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:bridge": "cd ../.. && uv run pyinstaller miqi.spec --noconfirm",
    "build:win": "npm run build:bridge && npm run build && npx electron-builder --win --publish never",
    "build:mac": "npm run build:bridge && npm run build && npx electron-builder --mac --publish never",
    "build:all": "npm run build:win",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "npx playwright test --config=playwright.config.ts --project=smoke",
    "test:electron": "npm run build && npx playwright test --config=playwright.config.ts --project=electron",
    "test:electron:log": "npm run build && npx playwright test --config=playwright.config.ts --project=electron 2>&1 | node scripts/tee.js test-reports/test-output.log",
    "test:report": "npx playwright show-report test-reports/html",
    "test:real-e2e": "npx vitest run tests/smoke/real-e2e.test.ts",
    "test:real-ui": "npx playwright test --config=playwright.config.ts --project=electron --grep \"Real Agent E2E\""
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.5",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.510.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.1.6",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "electron": "39.8.5",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.1.6",
    "typescript": "^5.8.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
